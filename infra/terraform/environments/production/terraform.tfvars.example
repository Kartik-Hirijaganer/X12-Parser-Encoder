app_env    = "production"
aws_region = "us-east-2"

github_repository           = "Kartik-Hirijaganer/X12-Parser-Encoder"
manage_github_oidc_provider = false

lambda_zip_path      = "../example/placeholder-lambda.zip"
lambda_architecture  = "x86_64"
enable_snapstart     = true
reserved_concurrency = 50
memory_mb            = 1024
timeout_s            = 30

price_class                  = "PriceClass_100"
enable_waf                   = true
waf_rate_limit_per_5_min     = 2000
waf_geo_allow_countries      = []

# Optional Phase 5 custom domain. Route 53 mode creates ACM validation
# records and an ALIAS record. External mode outputs the required records.
custom_domain = null
dns_provider  = "route53"
hosted_zone_id = null

# Replace before applying. This value is stored in Terraform state because
# CloudFront custom origin headers are stateful configuration.
origin_verify_header_value          = "replace-with-at-least-32-random-characters"
origin_verify_header_previous_value = ""
